# $HOME/.config/alacritty/alacritty.toml

# [window]
# padding = { x = 10, y = 10 }
# dynamic_padding = false

[colors]
# primary = { background = '0x1e1e2e', foreground = '0xf8f8f2' }
# normal = { black = '0x1c1c1c', red = '0xcc241d', green = '0x98971a', yellow = '0xd79921', blue = '0x458588', magenta = '0xb16286', cyan = '0x689d6a', white = '0xa89984' }
# bright = { black = '0x928374', red = '0xfb4934', green = '0xb8bb26', yellow = '0xfabd2f', blue = '0x83a598', magenta = '0xd3869b', cyan = '0x8ec07c', white = '0xebdbb2' }
#
[env]
WINIT_X11_SCALE_FACTOR = "1.0"

[font]
size = 20.0
normal.family = "JetBrainsMono Nerd Font"
bold.family = "JetBrainsMono Nerd Font"
italic.family = "JetBrainsMono Nerd Font"
bold_italic.family = "JetBrainsMono Nerd Font"

[selection]
semantic_escape_chars = ",│`|:\"' ()[]{}<>"
save_to_clipboard = true

[keyboard]
bindings = [
    { key = "Left",  mods = "Alt", chars = "\u001b[D" },
    { key = "Right", mods = "Alt", chars = "\u001b[C" }
]
